{
  "crons": [
    {
      "path": "/api/cron/generate?sport=mlb&refetch=true",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate?sport=nba&refetch=true",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate?sport=wnba&refetch=true",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-email?sport=mlb",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/post-twitter?sport=mlb",
      "schedule": "20 9 * * *"
    },
    {
      "path": "/api/cron/post-bluesky?sport=mlb",
      "schedule": "25 9 * * *"
    },
    {
      "path": "/api/cron/send-email?sport=nba",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/send-email?sport=wnba",
      "schedule": "40 9 * * *"
    },
    {
      "path": "/api/cron/send-team-email?sport=mlb",
      "schedule": "45 9 * * *"
    },
    {
      "path": "/api/cron/ad-stats-snapshot?sport=mlb",
      "schedule": "50 9 * * *"
    },
    {
      "path": "/api/cron/supervise",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "app/api/cron/post-bluesky/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "app/api/cron/post-facebook/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "app/api/cron/send-email/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/send-team-email/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/supervise/route.ts": {
      "maxDuration": 800
    }
  },
  "headers": [
    {
      "source": "/.well-known/atproto-did",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}

