{
  "crons": [
    {
      "path": "/api/cron/generate?sport=mlb",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate?sport=nba",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate?sport=wnba",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-email?sport=mlb",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron/post-twitter?sport=mlb",
      "schedule": "20 9 * * *"
    },
    {
      "path": "/api/cron/post-bluesky?sport=mlb",
      "schedule": "25 9 * * *"
    }
  ],
  "functions": {
    "app/api/cron/post-bluesky/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "app/api/cron/post-facebook/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/.well-known/atproto-did",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}

